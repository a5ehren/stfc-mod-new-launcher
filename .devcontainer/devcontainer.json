{
	// Linux-only build environment (AppImage/deb). macOS and Windows bundles require native hosts or CI.
	"name": "STFC Mod Launcher — Linux Build Only",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts",
			"nodeGypDependencies": true
		},
		"ghcr.io/devcontainers/features/rust:1": {
			"version": "stable",
			"profile": "default"
		}
	},
	"containerEnv": {
		"TAURI_BUILD_TARGET": "linux"
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"rust-lang.rust-analyzer",
				"Vue.volar",
				"biomejs.biome",
				"tauri-apps.tauri-vscode"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "biomejs.biome"
			}
		}
	},
	"forwardPorts": [1420],
	"remoteUser": "vscode"
}
