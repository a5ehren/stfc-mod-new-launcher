{
	"name": "stfc-mod-new-launcher",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc --noEmit && vite build",
		"build:macos": "pnpm tauri build --bundles app --target universal-apple-darwin",
		"build:windows": "pnpm exec tauri build --bundles msi --ci",
		"build:windows:arm64": "pnpm exec tauri build --bundles msi --target aarch64-pc-windows-msvc --ci",
		"build:linux": "pnpm exec tauri build --bundles deb,appimage --ci",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"tauri": "tauri",
		"prepare": "husky",
		"lint": "biome check --write",
		"format": "biome format --write",
		"check": "biome check"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-fs": "~2.5.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"toml": "^4.1.1",
		"vue": "^3.5.35"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tauri-apps/cli": "^2.11.2",
		"@types/node": "^24.13.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/test-utils": "^2.4.11",
		"git-format-staged": "^4.0.1",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"typescript": "~6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vue-tsc": "^3.3.4"
	},
	"packageManager": "pnpm@11.5.3"
}
